# Copy to .env and fill in. The .env file is gitignored.

# Musixmatch (server-side only). Get one at https://developer.musixmatch.com/
MUSIXMATCH_API_KEY=

# LALAL.AI (optional). Enables real stem-based energy envelopes when audio is provided.
# LALAL_API_KEY=

# Public base URL of the API (used by native clients to reach Expo Router API routes).
# On web, calls are relative. On native, set this to your EAS Hosting URL.
# EXPO_PUBLIC_API_BASE=https://your-app.expo.app
