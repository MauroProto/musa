{
  "expo": {
    "name": "MUSA",
    "slug": "musa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "musa",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#05060A",
    "ios": {
      "icon": "./assets/images/icon.png",
      "supportsTablet": true,
      "bundleIdentifier": "com.musa.app"
    },
    "android": {
      "package": "com.musa.app",
      "permissions": [
        "VIBRATE"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#05060A",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "output": "server",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-audio",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "musixmatchBaseUrl": "https://api.musixmatch.com/ws/1.1",
      "lalalBaseUrl": "https://www.lalal.ai/api",
      "router": {},
      "eas": {
        "projectId": "b42e4087-875c-4d04-92d0-f8f42eba92e4"
      }
    },
    "owner": "nachoestevo",
    "sdkVersion": "54.0.0",
    "runtimeVersion": "exposdk:54.0.0",
    "updates": {
      "url": "https://u.expo.dev/b42e4087-875c-4d04-92d0-f8f42eba92e4"
    }
  }
}
